generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Empresas ───────────────────────────────────────────────
model Company {
  id              String   @id @default(uuid())
  name            String
  cnpj            String   @unique
  taxRegime       String
  address         String?
  phone           String?
  email           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  documents       Document[]
  transactions    Transaction[]
  auditTrails     AuditTrail[]

  @@map("companies")
}

// ─── Usuários ────────────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("user")
  active      Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// ─── Documentos ──────────────────────────────────────────────
model Document {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  type              String
  status            String   @default("pending")
  originalFilename  String?
  fileUrl           String?
  mimeType          String?
  fileSizeBytes     Int?
  extractedData     String?
  confidenceScore   Float?
  number            String?
  series            String?
  issueDate         DateTime?
  dueDate           DateTime?
  totalValue        Float?
  issuerName        String?
  issuerCnpj        String?
  recipientName     String?
  recipientCnpj     String?
  fiscalValidation  String?
  complianceCheck   String?
  agentDecisions    String?
  reconciliationStatus String? @default("pending")
  reconciledWith    String?
  processingTimeMs  Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions      Transaction[]

  @@map("documents")
}

// ─── Transações / Lançamentos Contábeis ─────────────────────
model Transaction {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id])
  description String
  date        DateTime
  status      String   @default("draft")
  entries     String
  totalDebit  Float    @default(0)
  totalCredit Float    @default(0)
  isBalanced  Boolean  @default(false)
  aiConfidence   Float?
  aiReasoning    String?
  approvedBy     String?
  approvedAt     DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditTrails AuditTrail[]

  @@map("transactions")
}

// ─── Trilha de Auditoria (Imutável) ─────────────────────────
model AuditTrail {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  action        String
  entityType    String
  entityId      String
  performedBy   String
  agentType     String?
  oldValues     String?
  newValues     String?
  metadata      String?
  previousHash  String?
  currentHash   String
  createdAt     DateTime @default(now())

  @@map("audit_trails")
}

// ─── Resultados de Reconciliação ────────────────────────────
model ReconciliationRun {
  id              String   @id @default(uuid())
  companyId       String
  matchType       String
  status          String   @default("completed")
  matchesCount    Int      @default(0)
  unmatchedCount  Int      @default(0)
  totalMatchedValue   Float @default(0)
  totalUnmatchedValue Float @default(0)
  matches         String
  createdAt       DateTime @default(now())

  @@map("reconciliation_runs")
}
