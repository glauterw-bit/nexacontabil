// ─── Tarefas / Kanban ─────────────────────────────────────────
model Tarefa {
  id              String   @id @default(uuid())
  companyId       String   // empresa relacionada (opcional — escritório)
  company         Company  @relation(fields: [companyId], references: [id])
  titulo          String
  descricao       String?
  tipo            String   @default("geral") // obrigacao|documento|cobranca|geral|reuniao
  status          String   @default("backlog") // backlog|a_fazer|em_andamento|revisao|concluida|cancelada
  prioridade      String   @default("media") // baixa|media|alta|urgente
  responsavel     String?
  prazo           DateTime?
  concluidaEm    DateTime?
  tags            String?  // JSON array
  checklist       String?  // JSON array de subtarefas
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tarefas")
}

// ─── MEI — DASN-SIMEI ─────────────────────────────────────────
model MeiApuracao {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  competencia     String   // YYYY-MM ou YYYY (para DASN anual)
  tipo            String   @default("mensal") // mensal|anual_dasn
  receitaComercio Float    @default(0)
  receitaServicos Float    @default(0)
  receitaTotal    Float    @default(0)
  limiteAnual     Float    @default(81000)
  percentualUsado Float    @default(0)
  dasValor        Float    @default(0)
  dasInss         Float    @default(0)  // parte INSS
  dasIss          Float    @default(0)  // se serviços
  dasIcms         Float    @default(0)  // se comércio
  status          String   @default("calculado") // calculado|pago|atrasado
  dataPagamento   DateTime?
  codigoBarras    String?
  dasnEnviado     Boolean  @default(false) // para tipo=anual_dasn
  dasnRecibo      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

