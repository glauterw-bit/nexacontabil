}

// ─── Comunicados / Avisos ─────────────────────────────────────
model Comunicado {
  id              String   @id @default(uuid())
  escritorioId    String   // escritório remetente
  company         Company  @relation(fields: [escritorioId], references: [id])
  titulo          String
  corpo           String
  tipo            String   @default("geral") // geral|fiscal|trabalhista|urgente
  canal           String   @default("portal") // portal|email|whatsapp|todos
  destinatarios   String   @default("todos") // todos|selecionados (JSON array de companyIds)
  agendadoPara    DateTime?
  enviadoEm       DateTime?
  status          String   @default("rascunho") // rascunho|agendado|enviado|cancelado
  lidos           Int      @default(0)
  totalEnviados   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("comunicados")
}

// ─── Radar E-CAC / Situação Fiscal ───────────────────────────
model RadarEcacConsulta {
  id              String   @id @default(uuid())
  cnpj            String
  razaoSocial     String?
  situacao        String?  // ATIVA|SUSPENSA|INAPTA|BAIXADA
  dataAbertura    String?
  capitalSocial   Float?
  atividade       String?
  alertas         String?  // JSON array de alertas
  rawResponse     String?  // JSON da resposta completa
  fonte           String   @default("brasilapi") // brasilapi|receitaws
  ultimaConsulta  DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([cnpj])
  @@map("radar_ecac_consultas")
}

// ─── Central de Cobranças ─────────────────────────────────────
model CobrancaRegra {
  id              String   @id @default(uuid())
  companyId       String
  nome            String
  diasAntes       String   // JSON array de números (ex: [7, 3, 1])
  diasDepois      String   // JSON array de números (ex: [1, 5, 10])
  mensagemTemplate String
  canal           String   @default("email") // email|whatsapp|ambos
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lembretes       CobrancaLembrete[]

  @@index([companyId])
  @@map("cobranca_regras")
}

model CobrancaLembrete {
  id              String   @id @default(uuid())
  regraId         String
  regra           CobrancaRegra @relation(fields: [regraId], references: [id])
  boletoId        String
  companyId       String
  tipo            String   // antes|depois
  diasReferencia  Int      // quantos dias antes/depois do vencimento
  canal           String
  status          String   @default("enviado") // enviado|falhou|simulado
  mensagem        String?
  enviadoEm       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([companyId])
  @@index([boletoId])
  @@map("cobranca_lembretes")
}

// ─── Notificações in-app ──────────────────────────────────────
model Notification {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  userId          String?
  tipo            String   // obrigacao_vencendo|certidao_vencendo|nova_mensagem|tarefa_vencendo|honorario_vencendo|das_vencer
  titulo          String
  corpo           String
  link            String?
  lida            Boolean  @default(false)
  lidaEm          DateTime?
  createdAt       DateTime @default(now())

  @@map("notifications")
}

// ─── Plano de Contas (PCASP-like, configurável por empresa) ───
model ChartAccount {
  id          String   @id @default(uuid())
  companyId   String
  codigo      String   // 1.1.01.001 (estrutura hierárquica em string)
  nome        String
  tipo        String   // ativo|passivo|patrimonio|receita|despesa|conta_resultado
  natureza    String   // devedora|credora
  grau        Int      // 1=titulo, 2=subtitulo, 3=conta, 4=subconta
  parentId    String?
  parent      ChartAccount?  @relation("ChartAccountToParent", fields: [parentId], references: [id])
  children    ChartAccount[] @relation("ChartAccountToParent")
  active      Boolean  @default(true)
  permiteLancamento Boolean @default(true)
  spedCode    String?  // codigo SPED Contabil quando aplicavel
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, codigo])
  @@index([companyId, tipo])
  @@map("chart_accounts")
}

// ─── Centro de Custos ─────────────────────────────────────────
model CostCenter {
  id          String   @id @default(uuid())
  companyId   String
  codigo      String
  nome        String
  parentId    String?
  parent      CostCenter?  @relation("CostCenterToParent", fields: [parentId], references: [id])
  children    CostCenter[] @relation("CostCenterToParent")
  responsavel String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, codigo])
  @@map("cost_centers")
}

// ─── Calendario Fiscal (obrigações geradas automaticamente) ───
model FiscalCalendarItem {
  id              String    @id @default(uuid())
  companyId       String
  tipo            String    // DAS|DARF|GPS|FGTS|ISS|ICMS|DCTFWeb|DCTF|SPED_FISCAL|SPED_CONTRIB|ECD|ECF|EFD_REINF|ESOCIAL|DEFIS|DASN-SIMEI|DIRF|DIMOB|DMED
  descricao       String
  competencia     String    // YYYY-MM ou YYYY
  dataVencimento  DateTime
  valorEstimado   Float?
  valorPago       Float?
  status          String    @default("pendente") // pendente|em_apuracao|apurada|paga|vencida|isenta
  responsavelId   String?
  prioridade      String    @default("normal")   // baixa|normal|alta|critica
  alertaEnviadoEm DateTime?
  comprovanteUrl  String?
  observacoes     String?
  recorrencia     String?   // mensal|trimestral|anual|unico
  geradoEm        DateTime  @default(now())
  pagoEm          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, dataVencimento])
  @@index([status])
  @@map("fiscal_calendar_items")
}

// ─── DFC: Demonstracao do Fluxo de Caixa (cabecalho) ───────
model CashFlowStatement {
  id              String   @id @default(uuid())
  companyId       String
  periodoInicio   DateTime
  periodoFim      DateTime
  metodo          String   // direto|indireto
  geradoEm        DateTime @default(now())
  geradoPor       String?
  // totalizadores
  fcoOperacionais Float    @default(0) // FCO
  fcoInvestimento Float    @default(0) // FCI
  fcoFinanciamento Float   @default(0) // FCF
  variacaoCaixa   Float    @default(0)
  saldoInicial    Float    @default(0)
  saldoFinal      Float    @default(0)
  rubricasJson    String   // detalhamento por rubrica
  status          String   @default("rascunho") // rascunho|fechada
  createdAt       DateTime @default(now())

  @@index([companyId, periodoInicio])
  @@map("cash_flow_statements")
}

// ─── DMPL: Demonstracao das Mutacoes do PL ────────────────
model EquityMutationStatement {
  id              String   @id @default(uuid())
  companyId       String
  exercicio       Int
  // colunas DMPL
  capitalSocial       Float @default(0)
  reservasCapital     Float @default(0)
  reservasLucros      Float @default(0)
  acoesTesouraria     Float @default(0)
  lucrosAcumulados    Float @default(0)
  ajustesAvaliacao    Float @default(0)
  outrosResultados    Float @default(0)
  totalPL             Float @default(0)
  // linhas (movimentos no ano)
  linhasJson          String // [{ descricao, capitalSocial, reservas, ..., total }]
  status              String @default("rascunho")
  geradoEm            DateTime @default(now())
  createdAt           DateTime @default(now())

  @@unique([companyId, exercicio])
  @@map("equity_mutation_statements")
}

// ─── LGPD: Requisições de exportação e exclusão ───────────
model DataSubjectRequest {
  id              String    @id @default(uuid())
  companyId       String?
  userEmail       String
  tipo            String    // export|delete|rectify|object
  motivo          String?
  status          String    @default("recebida") // recebida|em_analise|atendida|rejeitada
  legalBasis      String?   // base legal para rejeicao (ex: obrigacao fiscal 5 anos)
  arquivoUrl      String?   // resultado export quando aplicavel
  atendidaEm      DateTime?
  atendidaPor     String?
  observacoes     String?
  ipSolicitante   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userEmail])
  @@index([status])
  @@map("data_subject_requests")
}

// ─── Carteira de Clientes por Analista ───────────────────────
model ClientAssignment {
  id           String   @id @default(uuid())
  companyId    String
  analystId    String   // User.id do analista responsavel
  assignedById String   // quem atribuiu (gerente/owner)
  assignedAt   DateTime @default(now())
  unassignedAt DateTime?
  active       Boolean  @default(true)
  motivo       String?  // motivo da atribuicao/desatribuicao
  observacoes  String?

  @@index([analystId, active])
  @@index([companyId, active])
  @@map("client_assignments")
}

// ─── Workflow Stage Config (estagios customizaveis) ─────────
model WorkflowStageConfig {
  id          String   @id @default(uuid())
  companyId   String?  // null = config global do escritorio; preenchido = override por cliente
  stageKey    String   // chave estavel: recepcao|lancamento|...
  label       String
  slaDias     Int      @default(3)
  ordem       Int      @default(0)
  color       String   @default("#6366f1")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, stageKey])
  @@index([companyId])
  @@map("workflow_stage_configs")
}

// ─── Workflow Task (Kanban operacional) ──────────────────────
model WorkflowTask {
  id           String   @id @default(uuid())
  companyId    String
  analystId    String?  // pode ser nulo (nao atribuida)
  stage        String   // recepcao|lancamento|conciliacao|apuracao|obrigacoes|revisao|entregue
  competencia  String   // YYYY-MM
  status       String   @default("pendente") // pendente|em_andamento|concluida|bloqueada
  prioridade   String   @default("normal")   // baixa|normal|alta|critica
  slaDate      DateTime // prazo do estagio
  startedAt    DateTime?
  completedAt  DateTime?
  completedBy  String?
  tempoSegundos Int?    // tempo real para completar (audit)
  observacoes  String?
  blockedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, stage, competencia])
  @@index([analystId, status])
  @@index([companyId, competencia])
  @@index([stage, status])
  @@map("workflow_tasks")
}

// ─── Comentarios em Tasks (historico imutavel com hash chain) ─
model WorkflowComment {
  id           String   @id @default(uuid())
  taskId       String
  userId       String
  userName     String   // snapshot do nome (audit)
  text         String
  // hash chain: cada comentario tem hash do anterior, formando audit imutavel
  prevHash     String?
  hash         String?  // sha256 do conteudo + prevHash
  attachmentUrl String?
  attachmentName String?
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@map("workflow_comments")
}

// ─── Cloud Connections (Google Drive / OneDrive / SharePoint) ─
model CloudConnection {
  id              String   @id @default(uuid())
  provider        String   // google_drive | microsoft_onedrive | microsoft_sharepoint
  label           String   // apelido escolhido pelo admin (ex: "Drive Escritorio")
  accountEmail    String   // e-mail do owner da conta Drive conectada
  scope           String   // 'readonly' | 'full'
  encryptedAccessToken  String  // AES-256-GCM encrypted
  encryptedRefreshToken String? // refresh para renovacao automatica
  tokenExpiresAt  DateTime
  rootFolderId    String?  // opcional: limitar busca a uma pasta especifica
  createdById     String   // user que conectou
  active          Boolean  @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([provider, active])
  @@map("cloud_connections")
}

// ─── Document Query History (buscas em linguagem natural) ────
model DocumentQuery {
  id              String   @id @default(uuid())
  userId          String
  companyId       String?
  queryText       String   // pergunta original em linguagem natural
  parsedFilters   String?  // JSON dos filtros derivados pela IA
  filesFoundCount Int      @default(0)
  filesAnalyzed   Int      @default(0)
  analysisResult  String?  // JSON com analise estruturada
  durationMs      Int?
  tokensUsed      Int?     // estimativa custo Claude
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([companyId])
  @@map("document_queries")
}

// ─── Generated Reports (relatorios PDF/JSON gerados) ─────────
model GeneratedReport {
  id              String   @id @default(uuid())
  companyId       String?
  userId          String
  queryId         String?  // referencia para DocumentQuery
  title           String
  contentJson     String   // dados estruturados do relatorio
  format          String   @default("json") // json | pdf | xlsx
  fileUrl         String?  // R2/B2 quando salvo
  hash            String   // SHA-256 do contentJson para integridade
  createdAt       DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId])
  @@map("generated_reports")
}

// ─── Fechamento Mensal (lock de periodo) ─────────────────────
model AccountingPeriodClosing {
  id              String   @id @default(uuid())
  companyId       String
  ano             Int
  mes             Int      // 1-12
  status          String   @default("em_andamento") // em_andamento|fechado|reaberto
  checklistJson   String?  // estado do checklist do fechamento
  closedAt        DateTime?
  closedBy        String?
  reopenedAt      DateTime?
  reopenedBy      String?
  reopenedMotivo  String?
  hash            String?  // hash dos lancamentos no momento do lock (audit imutavel)
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, ano, mes])
  @@index([companyId, status])
  @@map("accounting_period_closings")
}
