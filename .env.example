# ============================================================
# NEXACONTABIL / AURA ACCOUNTING — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
FRONTEND_PORT=3010
PYTHON_AI_PORT=8000

# ─── Banco de dados ───────────────────────────────────────────
# Desenvolvimento: SQLite (sem instalação extra)
DATABASE_URL=file:./dev.db
# Produção: PostgreSQL
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/nexacontabil

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=troque-esta-chave-em-producao-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Portal do Cliente ───────────────────────────────────────
PORTAL_JWT_SECRET=troque-esta-chave-em-producao-min-32-chars
NEXT_PUBLIC_PORTAL_URL=http://localhost:3010/portal

# ─── Criptografia de certificados digitais ───────────────────
APP_SECRET=troque-esta-chave-em-producao-min-32-chars

# ─── Serviços internos ────────────────────────────────────────
PYTHON_AI_URL=http://localhost:8000
NODEJS_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ─── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Pinecone (RAG / busca vetorial) — opcional ───────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=nexacontabil

# ─── AWS S3 (armazenamento de documentos) — opcional ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=nexacontabil-docs

# ─── Redis — opcional (cache / filas) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── WhatsApp / Evolution API ────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-evolution
WHATSAPP_WEBHOOK_BASE_URL=http://localhost:8000

# ─── NFe.io — Emissão NF-e / NFS-e ──────────────────────────
# Cadastre-se em https://nfe.io
NFEIO_API_KEY=
NFEIO_COMPANY_ID=
NFEIO_ENV=homologacao   # homologacao | producao

# ─── Focus NFe (alternativa ao NFe.io) ───────────────────────
FOCUSNFE_TOKEN=
FOCUSNFE_ENV=homologacao

# ─── BirdID — Certificado Digital em Nuvem ───────────────────
BIRDID_CLIENT_ID=
BIRDID_CLIENT_SECRET=
BIRDID_API_URL=https://api.birdid.com.br/v0

# ─── Asaas — Boleto + PIX ────────────────────────────────────
# Cadastre-se em https://asaas.com
ASAAS_API_KEY=
ASAAS_ENV=sandbox   # sandbox | production

# ─── Resend — E-mail transacional ────────────────────────────
# Cadastre-se em https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@seudominio.com.br

# ─── E-mail IMAP — Captura automática de XMLs ────────────────
EMAIL_IMAP_HOST=imap.seudominio.com.br
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_IMAP_TLS=true

# ─── Open Finance / Bancos ───────────────────────────────────
OPENFINANCE_CLIENT_ID=
OPENFINANCE_CLIENT_SECRET=

# ─── eSocial ─────────────────────────────────────────────────
ESOCIAL_AMBIENTE=2   # 1=produção | 2=homologação
ESOCIAL_WSDL_URL=https://webservices.producaorestrita.esocial.gov.br

# ─── SEFAZ ───────────────────────────────────────────────────
SEFAZ_UF=SP
SEFAZ_AMBIENTE=2   # 1=produção | 2=homologação

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
