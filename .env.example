# ============================================================
# AURA ACCOUNTING — Environment Variables
# ============================================================

# App
NODE_ENV=development
APP_PORT=3000
PYTHON_AI_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://aura:aura_secret@localhost:5432/aura_accounting
POSTGRES_USER=aura
POSTGRES_PASSWORD=aura_secret
POSTGRES_DB=aura_accounting

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Vector DB (Pinecone)
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=aura-accounting

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=aura-accounting-docs

# Internal Service URLs
PYTHON_AI_URL=http://python-ai:8000
NODEJS_API_URL=http://nodejs-api:3001

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
